{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "env": {
    "NEXT_PUBLIC_API_URL": "@nepse_api_url"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/app/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/$1"
    }
  ]
}
